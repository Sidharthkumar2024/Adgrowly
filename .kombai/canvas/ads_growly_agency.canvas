      "html": "<div class=\"bg-[#0B0C10] text-white font-inter selection:bg-[#66FCF1]/30 selection:text-[#66FCF1] overflow-hidden relative\" data-kid=\"0\">\n    \n    <div class=\"absolute inset-0 pointer-events-none opacity-[0.03] z-50\" style=\"background-image: radial-gradient(#66FCF1 1px, transparent 1px); background-size: 40px 40px;\" data-kid=\"1\"></div>\n    \n    <style data-kid=\"2\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Roboto+Mono:wght@400;500;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .font-inter { font-family: 'Inter', sans-serif; }\n        .font-mono { font-family: 'Roboto Mono', monospace; }\n        \n        .text-cyan { color: #66FCF1; }\n        .bg-cyan { background-color: #66FCF1; }\n        .border-cyan { border-color: #66FCF1; }\n        \n        .glow-cyan { text-shadow: 0 0 20px rgba(102, 252, 241, 0.5); }\n        .box-glow-cyan { box-shadow: 0 0 30px rgba(102, 252, 241, 0.2); }\n        \n        .glass-card { \n            background: rgba(31, 40, 51, 0.85); \n            backdrop-filter: blur(12px); \n            border: 1px solid rgba(102, 252, 241, 0.15); \n        }\n\n        .logo-mark { filter: drop-shadow(0 0 12px rgba(102, 252, 241, 0.5)); }\n\n        .tilt-3d {\n            transform-style: preserve-3d;\n            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s, border-color 0.4s;\n        }\n        .tilt-3d:hover {\n            transform: perspective(1200px) rotateX(4deg) rotateY(-5deg) translateY(-8px);\n        }\n        .tilt-3d-r:hover {\n            transform: perspective(1200px) rotateX(4deg) rotateY(5deg) translateY(-8px);\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0) translateX(0); }\n            50% { transform: translateY(-15px) translateX(5px); }\n        }\n        .animate-float { animation: float 6s ease-in-out infinite; }\n        \n        @keyframes radar-rotate {\n            from { transform: translate(-50%, -50%) rotate(0deg); }\n            to { transform: translate(-50%, -50%) rotate(360deg); }\n        }\n        .animate-radar { animation: radar-rotate 5s linear infinite; }\n\n        @keyframes spin-slow {\n            from { transform: rotate(0deg); }\n            to { transform: rotate(360deg); }\n        }\n        .animate-spin-slow { animation: spin-slow 30s linear infinite; }\n\n        input[type=\"range\"] {\n            -webkit-appearance: none;\n            width: 100%;\n            height: 4px;\n            background: #1F2833;\n            border-radius: 5px;\n            outline: none;\n        }\n        input[type=\"range\"]::-webkit-slider-thumb {\n            -webkit-appearance: none;\n            width: 24px;\n            height: 24px;\n            background: #66FCF1;\n            border: 4px solid #1F2833;\n            border-radius: 4px;\n            cursor: pointer;\n            box-shadow: 0 0 20px rgba(102, 252, 241, 0.6);\n            transition: all 0.2s;\n        }\n        input[type=\"range\"]::-webkit-slider-thumb:hover {\n            transform: scale(1.2);\n        }\n\n        .ambient-glow {\n            position: absolute;\n            width: 600px;\n            height: 600px;\n            background: radial-gradient(circle, rgba(102, 252, 241, 0.05) 0%, transparent 70%);\n            border-radius: 50%;\n            z-index: 0;\n            pointer-events: none;\n        }\n    </style>\n\n    \n    <nav class=\"relative z-50 px-10 py-8 flex justify-between items-center bg-[#0B0C10]/80 backdrop-blur-md border-b border-white/5\" data-kid=\"3\">\n        <div class=\"flex items-center gap-3\" data-kid=\"4\">\n            <svg viewBox=\"0 0 48 48\" class=\"w-11 h-11 logo-mark\" aria-label=\"Ads Growly logomark\" data-kid=\"5\">\n                <defs data-kid=\"6\">\n                    <linearGradient id=\"agGrad\" x1=\"0\" y1=\"48\" x2=\"48\" y2=\"0\" gradientUnits=\"userSpaceOnUse\" data-kid=\"7\">\n                        <stop offset=\"0\" stop-color=\"#2BB3AA\" data-kid=\"8\"></stop>\n                        <stop offset=\"1\" stop-color=\"#66FCF1\" data-kid=\"9\"></stop>\n                    </linearGradient>\n                </defs>\n                <rect x=\"1.5\" y=\"1.5\" width=\"45\" height=\"45\" rx=\"12\" fill=\"rgba(102,252,241,0.06)\" stroke=\"rgba(102,252,241,0.35)\" stroke-width=\"1.5\" data-kid=\"10\"></rect>\n                <rect x=\"9\" y=\"29\" width=\"5.5\" height=\"11\" rx=\"1.5\" fill=\"url(#agGrad)\" opacity=\"0.45\" data-kid=\"11\"></rect>\n                <rect x=\"17.5\" y=\"23\" width=\"5.5\" height=\"17\" rx=\"1.5\" fill=\"url(#agGrad)\" opacity=\"0.7\" data-kid=\"12\"></rect>\n                <rect x=\"26\" y=\"16\" width=\"5.5\" height=\"24\" rx=\"1.5\" fill=\"url(#agGrad)\" data-kid=\"13\"></rect>\n                <path d=\"M10 22 L22 13 L28 17 L37 9.5\" stroke=\"#66FCF1\" stroke-width=\"2.6\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\" data-kid=\"14\"></path>\n                <path d=\"M38.6 4.2 l0.9 1.9 1.8-0.8 -0.5 1.9 2.1-0.3 -1.4 1.7 1.6 1 -2.1 0.6 0.5 2 -1.9-1 -1 2.1 -1-2.1 -1.9 1 0.5-2 -2.1-0.6 1.6-1 -1.4-1.7 2.1 0.3 -0.5-1.9 1.8 0.8 z\" fill=\"#66FCF1\" data-kid=\"15\"></path>\n            </svg>\n            <span class=\"font-inter text-2xl font-extrabold tracking-tight\" data-kid=\"16\">Ads<span class=\"text-cyan\" data-kid=\"17\">Growly</span></span>\n        </div>\n        <div class=\"hidden md:flex items-center gap-10 font-mono text-xs uppercase tracking-widest text-[#C5C6C7]\" data-kid=\"18\">\n            <a href=\"#\" class=\"hover:text-cyan transition-colors\" data-kid=\"19\">Stack</a>\n            <a href=\"#\" class=\"hover:text-cyan transition-colors\" data-kid=\"20\">Protocol</a>\n            <a href=\"#\" class=\"hover:text-cyan transition-colors\" data-kid=\"21\">Industries</a>\n          