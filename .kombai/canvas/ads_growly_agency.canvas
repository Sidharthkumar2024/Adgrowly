      "html": "<div class=\"bg-[#0A1128] text-white selection:bg-[#00E676]/30 selection:text-white\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Syne:wght@700;800&family=Fira+Code:wght@400;500&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        :root {\n            --color-navy: #0A1128;\n            --color-obsidian: #101820;\n            --color-aurora: #00E676;\n            --color-violet: #7C4DFF;\n            --color-mint: #B9F6CA;\n        }\n\n        .font-syne { font-family: 'Syne', sans-serif; }\n        .font-inter { font-family: 'Inter', sans-serif; }\n        .font-mono { font-family: 'Fira Code', monospace; }\n\n        .aurora-glow {\n            background: radial-gradient(circle at 50% 50%, rgba(0, 230, 118, 0.12) 0%, transparent 70%);\n        }\n        .aurora-violet {\n            background: radial-gradient(circle at 80% 20%, rgba(124, 77, 255, 0.1) 0%, transparent 60%);\n        }\n\n        .glass-panel {\n            background: rgba(16, 24, 32, 0.7);\n            backdrop-filter: blur(20px);\n            border: 1px solid rgba(255, 255, 255, 0.08);\n        }\n\n        .neo-brutal {\n            border: 1px solid rgba(255, 255, 255, 0.15);\n            box-shadow: 8px 8px 0px rgba(0, 230, 118, 0.2);\n        }\n        .neo-brutal-violet {\n            border: 1px solid rgba(255, 255, 255, 0.15);\n            box-shadow: 8px 8px 0px rgba(124, 77, 255, 0.25);\n        }\n\n        .diagonal-hero {\n            clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 90%);\n        }\n\n        /* 3D perspective tilts */\n        .tilt-wrap { perspective: 1200px; }\n        .tilt-3d {\n            transform-style: preserve-3d;\n            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s ease, border-color 0.4s ease;\n        }\n        .tilt-wrap:hover .tilt-3d, .tilt-3d:hover {\n            transform: rotateX(4deg) rotateY(-5deg) translateY(-6px);\n        }\n        .tilt-3d-r:hover {\n            transform: rotateX(-3deg) rotateY(5deg) translateY(-6px);\n        }\n\n        @keyframes float {\n            0%, 100% { transform: translateY(0px); }\n            50% { transform: translateY(-20px); }\n        }\n        @keyframes subtle-pulse {\n            0%, 100% { transform: scale(1); opacity: 1; }\n            50% { transform: scale(1.1); opacity: 0.8; }\n        }\n        .animate-subtle-pulse { animation: subtle-pulse 3s ease-in-out infinite; }\n        .animate-float { animation: float 6s ease-in-out infinite; }\n\n        @keyframes pulse-ring {\n            0% { transform: scale(0.33); opacity: 1; }\n            80%, 100% { transform: scale(3); opacity: 0; }\n        }\n        .pulse-ring-effect { animation: pulse-ring 3s cubic-bezier(0.455, 0.03, 0.515, 0.955) infinite; }\n\n        @keyframes dash-flow {\n            to { stroke-dashoffset: -24; }\n        }\n        .dash-flow { animation: dash-flow 2s linear infinite; }\n\n        .terminal-glow {\n            box-shadow: 0 0 40px rgba(0, 230, 118, 0.1);\n        }\n\n        .sector-tile { transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); }\n        .sector-tile:hover {\n            border-color: rgba(0, 230, 118, 0.6);\n            box-shadow: 0 0 30px rgba(0, 230, 118, 0.15), inset 0 0 30px rgba(0, 230, 118, 0.05);\n            transform: translateY(-4px);\n        }\n        .sector-tile:hover .sector-icon { color: #00E676; text-shadow: 0 0 20px rgba(0,230,118,0.6); }\n        .sector-tile:hover .sector-label { color: #B9F6CA; }\n    </style>\n\n    \n    <nav class=\"absolute top-0 left-0 w-full z-50 px-12 py-8 flex justify-between items-center\" data-kid=\"2\">\n        <div class=\"flex items-center gap-3 group cursor-pointer\" data-kid=\"3\">\n            <svg width=\"44\" height=\"44\" viewBox=\"0 0 44 44\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" class=\"shrink-0\" data-kid=\"4\">\n                <defs data-kid=\"5\">\n                    <linearGradient id=\"agLogoGrad\" x1=\"4\" y1=\"40\" x2=\"40\" y2=\"4\" gradientUnits=\"userSpaceOnUse\" data-kid=\"6\">\n                        <stop offset=\"0%\" stop-color=\"#00E676\" data-kid=\"7\"></stop>\n                        <stop offset=\"55%\" stop-color=\"#B9F6CA\" data-kid=\"8\"></stop>\n                        <stop offset=\"100%\" stop-color=\"#7C4DFF\" data-kid=\"9\"></stop>\n                    </linearGradient>\n                </defs>\n                <rect x=\"1.5\" y=\"1.5\" width=\"41\" height=\"41\" stroke=\"rgba(255,255,255,0.15)\" stroke-width=\"1\" data-kid=\"10\"></rect>\n                <path d=\"M6 37 L14 15 L19 27 L26 6 L31 22 L38 9\" stroke=\"url(#agLogoGrad)\" stroke-width=\"3.5\" stroke-linecap=\"square\" stroke-linejoin=\"miter\" fill=\"none\" data-kid=\"11\"></path>\n                <path d=\"M6 37 H38\" stroke=\"url(#agLogoGrad)\" stroke-width=\"1.5\" opacity=\"0.4\" data-kid=\"12\"></path>\n                <circle cx=\"38\" cy=\"9\" r=\"2.5\" fill=\"#7C4DFF\" data-kid=\"13\"></circle>\n                <circle cx=\"26\" cy=\"6\" r=\"2\" fill=\"#00E676\" data-kid=\"14\"></circle>\n            </svg>\n            <div class=\"flex flex-col\" data-kid=\"15\">\n                <span class=\"font-syne text-2xl tracking-tighter leading-none\" data-kid=\"16\">ADS GROWLY</span>\n                <span class=\"font-mono text-[8px] text-[#00E676]/70 uppercase tracking-[0.35em] mt-1\" data-kid=\"17\">Growth Command</span>\n            </div>\n        </div>\n        <div class=\"hidden md:flex items-center gap-12 font-inter text-xs font-semibold tracking-widest uppercase text-gray-400\" data-kid=\"18\">\n            <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"19\">Strategy</a>\n            <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"20\">Sequence</a>\n            <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"21\">Sectors</a>\n            <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"22\">Tiers</a>\n            <a href=\"#\" class=\"px-6 py-3 border border-white/10 rounded-xs hover:bg-white/5 transition-colors text-white\" data-kid=\"23\">Dominate Now</a>\n        </div>\n    </nav>\n\n    \n    <section class=\"relative h-[900px] overflow-hidden diagonal-hero\" data-kid=\"24\">\n        <div class=\"flex h-full\" data-kid=\"25\">\n            <div class=\"w-full lg:w-[55%] flex flex-col justify-center px-12 lg:px-24 bg-[#0A1128] z-20\" data-kid=\"26\">\n                <div class=\"inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/5 border border-white/10 w-fit mb-10\" data-kid=\"27\">\n                    <span class=\"w-2 h-2 rounded-full bg-[#00E676] shadow-[0_0_10px_#00E676]\" data-kid=\"28\"></span>\n                    <span class=\"text-[10px] font-mono uppercase tracking-[0.2em] text-[#B9F6CA]\" data-kid=\"29\">Local Presence Dominance Protocol v4.0</span>\n                </div>\n                \n                <h1 class=\"font-syne text-[clamp(4rem,8vw,9rem)] leading-[0.85] mb-10 tracking-tighter\" data-kid=\"30\">\n                    UNFAIR LOCAL<br data-kid=\"31\">\n                    <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-[#00E676] via-[#B9F6CA] to-[#7C4DFF]\" data-kid=\"32\">ADVANTAGE</span>\n                </h1>\n                \n                <p class=\"font-inter text-xl lg:text-2xl text-gray-400 max-w-xl mb-14 leading-relaxed\" data-kid=\"33\">\n                    Ads Growly engineers high-yield GMB and paid traffic systems. We don't just \"manage accounts\"—we seize market share for Canadian service leaders.\n                </p>\n\n                <div class=\"flex flex-wrap gap-6\" data-kid=\"34\">\n                    <button class=\"px-10 py-6 bg-[#00E676] text-[#0A1128] font-syne font-bold rounded-xs hover:shadow-[0_0_30px_rgba(0,230,118,0.4)] transition-all flex items-center gap-3 text-lg group\" data-kid=\"35\">\n                        INITIALIZE GROWTH\n                        <i class=\"ti ti-arrow-right group-hover:translate-x-1 transition-transform\" data-kid=\"36\"></i>\n                    </button>\n                    <div class=\"flex items-center gap-4 px-8 py-6 border border-white/10 rounded-xs glass-panel cursor-pointer hover:bg-white/5 transition-colors\" data-kid=\"37\">\n                        <i class=\"ti ti-player-play-filled text-[#7C4DFF]\" data-kid=\"38\"></i>\n                        <span class=\"font-syne font-bold uppercase tracking-widest text-sm\" data-kid=\"39\">System Walkthrough</span>\n                    </div>\n                </div>\n\n                <div class=\"flex items-center gap-10 mt-16 pt-10 border-t border-white/5\" data-kid=\"40\">\n                    <div data-kid=\"41\">\n                        <div class=\"font-syne text-3xl text-[#00E676]\" data-kid=\"42\">120+</div>\n                        <div class=\"font-mono text-[9px] text-gray-500 uppercase tracking-widest mt-1\" data-kid=\"43\">Active Systems</div>\n                    </div>\n                    <div class=\"w-px h-10 bg-white/10\" data-kid=\"44\"></div>\n                    <div data-kid=\"45\">\n                        <div class=\"font-syne text-3xl text-[#00E676]\" data-kid=\"46\">$12M</div>\n                        <div class=\"font-mono text-[9px] text-gray-500 uppercase tracking-widest mt-1\" data-kid=\"47\">CAD Managed</div>\n                    </div>\n                    <div class=\"w-px h-10 bg-white/10\" data-kid=\"48\"></div>\n                    <div data-kid=\"49\">\n                        <div class=\"font-syne text-3xl text-[#00E676]\" data-kid=\"50\">98.4%</div>\n                        <div class=\"font-mono text-[9px] text-gray-500 uppercase tracking-widest mt-1\" data-kid=\"51\">Retention</div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"hidden lg:block w-[45%] relative bg-[#080C1B]\" data-kid=\"52\">\n                <video src=\"https://videos.pexels.com/video-files/34336322/14545802_360_640_30fps.mp4\" poster=\"https://images.pexels.com/videos/34336322/pexels-photo-34336322.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=1200&w=630\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover opacity-60 mix-blend-screen\" data-kid=\"53\"></video>\n                <div class=\"absolute inset-0 bg-gradient-to-r from-[#0A1128] via-transparent to-transparent\" data-kid=\"54\"></div>\n                \n                <div class=\"absolute top-[20%] right-[10%] w-72 glass-panel p-8 rounded-xs neo-brutal animate-float z-30 border-l-2 border-l-[#00E676]\" data-kid=\"55\">\n                    <div class=\"flex justify-between items-start mb-6\" data-kid=\"56\">\n                        <span class=\"text-[10px] font-mono text-gray-500 uppercase tracking-widest\" data-kid=\"57\">Market Status</span>\n                        <div class=\"px-2 py-0.5 bg-[#00E676]/20 text-[#00E676] text-[8px] font-bold rounded-full shadow-[0_0_10px_rgba(0,230,118,0.2)]\" data-kid=\"58\">LIVE PULSE</div>\n                    </div>\n                    <div class=\"text-3xl font-mono mb-2 tracking-tighter text-[#00E676]\" data-kid=\"59\">DOMINATING</div>\n                    <div class=\"flex items-end gap-1 h-12\" data-kid=\"60\">\n                        <div class=\"w-2 h-[40%] bg-[#00E676]\" data-kid=\"61\"></div>\n                        <div class=\"w-2 h-[70%] bg-[#00E676]\" data-kid=\"62\"></div>\n                        <div class=\"w-2 h-[100%] bg-[#00E676]\" data-kid=\"63\"></div>\n                        <div class=\"w-2 h-[60%] bg-[#00E676]\" data-kid=\"64\"></div>\n                        <div class=\"w-2 h-[85%] bg-[#00E676]\" data-kid=\"65\"></div>\n                        <div class=\"w-2 h-[30%] bg-[#00E676]\" data-kid=\"66\"></div>\n                    </div>\n                </div>\n\n                <div class=\"absolute bottom-[25%] left-0 w-80 glass-panel p-8 rounded-xs neo-brutal shadow-[8px_8px_0px_rgba(124,77,255,0.2)] z-30\" style=\"animation-delay: -3s;\" data-kid=\"67\">\n                    <div class=\"text-[10px] font-mono text-gray-500 uppercase tracking-widest mb-4\" data-kid=\"68\">Targeting Vector</div>\n                    <div class=\"text-2xl font-syne mb-4 tracking-tight\" data-kid=\"69\">ONTARIO / CANADA</div>\n                    <div class=\"flex items-center gap-2 text-xs font-mono text-[#7C4DFF]\" data-kid=\"70\">\n                        <i class=\"ti ti-map-pin\" data-kid=\"71\"></i>\n                        <span data-kid=\"72\">GEO-RADIUS: 50KM</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-12 lg:px-24 max-w-7xl mx-auto\" data-kid=\"73\">\n        <div class=\"mb-24 flex flex-col md:flex-row md:items-end justify-between gap-12\" data-kid=\"74\">\n            <div data-kid=\"75\">\n                <span class=\"text-[#00E676] font-mono text-xs uppercase tracking-[0.3em] mb-4 block\" data-kid=\"76\">Core Capabilities</span>\n                <h2 class=\"font-syne text-6xl lg:text-8xl leading-none tracking-tighter\" data-kid=\"77\">OUR GROWTH<br data-kid=\"78\"><span class=\"text-gray-600\" data-kid=\"79\">STAKED UNITS</span></h2>\n            </div>\n            <p class=\"font-inter text-gray-400 max-w-md text-lg leading-relaxed\" data-kid=\"80\">\n                We deploy three distinct systems designed to interlock and multiply your local footprint.\n            </p>\n        </div>\n\n        <div class=\"grid grid-cols-1 gap-12\" data-kid=\"81\">\n            <div class=\"tilt-wrap\" data-kid=\"82\">\n            <div class=\"tilt-3d group glass-panel flex flex-col lg:flex-row items-stretch min-h-[500px] rounded-xs overflow-hidden border-white/5 hover:border-[#7C4DFF]/40 relative\" data-kid=\"83\">\n                <div class=\"absolute top-0 right-0 w-32 h-32 bg-[#7C4DFF]/5 blur-3xl rounded-full -mr-16 -mt-16 group-hover:bg-[#7C4DFF]/20 transition-all\" data-kid=\"84\"></div>\n                <div class=\"w-full lg:w-1/2 p-10 lg:p-14 flex flex-col justify-center relative z-10\" data-kid=\"85\">\n                    <div class=\"w-16 h-16 bg-[#7C4DFF]/10 flex items-center justify-center rounded-xs mb-6\" data-kid=\"86\">\n                        <i class=\"ti ti-brand-meta text-4xl text-[#7C4DFF]\" data-kid=\"87\"></i>\n                    </div>\n                    <h3 class=\"font-syne text-5xl mb-4\" data-kid=\"88\">Meta Ads Engine</h3>\n                    <p class=\"font-inter text-gray-400 text-lg mb-8 leading-relaxed\" data-kid=\"89\">\n                        Hyper-granular audience segmentation combined with high-frequency creative refreshes. We don't just scroll-stop; we capture interest and convert it into direct inquiries.\n                    </p>\n                    <div class=\"flex gap-4\" data-kid=\"90\">\n                        <span class=\"px-3 py-1 bg-white/5 border border-white/10 text-[10px] font-mono text-gray-300\" data-kid=\"91\">RETARGETING</span>\n                        <span class=\"px-3 py-1 bg-white/5 border border-white/10 text-[10px] font-mono text-gray-300\" data-kid=\"92\">LTV FOCUS</span>\n                    </div>\n                </div>\n                <div class=\"w-full lg:w-1/2 relative overflow-hidden bg-black\" data-kid=\"93\">\n                    <img src=\"https://images.unsplash.com/photo-1671519821564-ced7e41ee7ae?auto=format&w=1000&q=80&fit=crop\" alt=\"3D cubes\" class=\"w-full h-full object-cover opacity-70 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"94\">\n                    <div class=\"absolute inset-0 bg-gradient-to-r from-black/60 via-[#7C4DFF]/10 to-transparent\" data-kid=\"95\"></div>\n                </div>\n            </div>\n            </div>\n\n            <div class=\"tilt-wrap\" data-kid=\"96\">\n            <div class=\"tilt-3d tilt-3d-r group glass-panel flex flex-col lg:flex-row-reverse items-stretch min-h-[450px] rounded-xs overflow-hidden border-white/5 hover:border-[#00E676]/30\" data-kid=\"97\">\n                <div class=\"w-full lg:w-1/2 p-10 lg:p-14 flex flex-col justify-center\" data-kid=\"98\">\n                    <div class=\"w-16 h-16 bg-[#00E676]/10 flex items-center justify-center rounded-xs mb-6\" data-kid=\"99\">\n                        <i class=\"ti ti-brand-google text-4xl text-[#00E676]\" data-kid=\"100\"></i>\n                    </div>\n                    <h3 class=\"font-syne text-5xl mb-4\" data-kid=\"101\">Google Ads Core</h3>\n                    <p class=\"font-inter text-gray-400 text-lg mb-8 leading-relaxed\" data-kid=\"102\">\n                        Dominating the search intent lifecycle. We position your services at the exact micro-moment a lead in your service area is ready to hire. High intent, zero waste.\n                    </p>\n                    <div class=\"flex gap-4\" data-kid=\"103\">\n                        <span class=\"px-3 py-1 bg-white/5 border border-white/10 text-[10px] font-mono text-gray-300\" data-kid=\"104\">SEARCH DOMINANCE</span>\n                        <span class=\"px-3 py-1 bg-white/5 border border-white/10 text-[10px] font-mono text-gray-300\" data-kid=\"105\">CONVERSION TRACKING</span>\n                    </div>\n                </div>\n                <div class=\"w-full lg:w-1/2 bg-[#101820] flex items-center justify-center p-20\" data-kid=\"106\">\n                    <i class=\"ti ti-mouse-pointer text-[180px] text-[#00E676] opacity-10 group-hover:opacity-40 group-hover:scale-110 transition-all duration-700\" data-kid=\"107\"></i>\n                </div>\n            </div>\n            </div>\n\n            <div class=\"tilt-wrap\" data-kid=\"108\">\n            <div class=\"tilt-3d group glass-panel flex flex-col lg:flex-row items-stretch min-h-[450px] rounded-xs overflow-hidden border-white/5 hover:border-white/20\" data-kid=\"109\">\n                <div class=\"w-full lg:w-1/2 p-10 lg:p-14 flex flex-col justify-center\" data-kid=\"110\">\n                    <div class=\"w-16 h-16 bg-white/5 flex items-center justify-center rounded-xs mb-6\" data-kid=\"111\">\n                        <i class=\"ti ti-building-store text-4xl text-white\" data-kid=\"112\"></i>\n                    </div>\n                    <h3 class=\"font-syne text-5xl mb-4\" data-kid=\"113\">GMB Optimizer</h3>\n                    <p class=\"font-inter text-gray-400 text-lg mb-8 leading-relaxed\" data-kid=\"114\">\n                        The Crown Jewel of Local SEO. We engineer your Google Business Profile to win the 3-pack consistently. Reviews, citations, and proximity signals all firing in sync.\n                    </p>\n                    <div class=\"flex gap-4\" data-kid=\"115\">\n                        <span class=\"px-3 py-1 bg-white/5 border border-white/10 text-[10px] font-mono text-gray-300\" data-kid=\"116\">3-PACK RANKING</span>\n                        <span class=\"px-3 py-1 bg-white/5 border border-white/10 text-[10px] font-mono text-gray-300\" data-kid=\"117\">LOCAL CITATIONS</span>\n                    </div>\n                </div>\n                <div class=\"w-full lg:w-1/2 bg-gradient-to-br from-[#101820] to-[#0A1128] flex items-center justify-center p-20 overflow-hidden\" data-kid=\"118\">\n                    <div class=\"relative group-hover:scale-110 transition-transform duration-700\" data-kid=\"119\">\n                        <div class=\"absolute inset-0 bg-white/5 rounded-full scale-150 animate-pulse\" data-kid=\"120\"></div>\n                        <i class=\"ti ti-crown text-[140px] text-white opacity-20 group-hover:opacity-100 transition-opacity duration-700 group-hover:drop-shadow-[0_0_30px_rgba(255,255,255,0.3)]\" data-kid=\"121\"></i>\n                    </div>\n                </div>\n            </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-12 lg:px-24 bg-[#080C1B] relative overflow-hidden\" data-kid=\"122\">\n        <div class=\"absolute inset-0 aurora-violet\" data-kid=\"123\"></div>\n        <div class=\"max-w-7xl mx-auto relative z-10\" data-kid=\"124\">\n            <div class=\"flex flex-col lg:flex-row gap-24\" data-kid=\"125\">\n                <div class=\"lg:w-2/5\" data-kid=\"126\">\n                    <span class=\"text-[#00E676] font-mono text-xs uppercase tracking-[0.3em] mb-4 block\" data-kid=\"127\">Operation Order</span>\n                    <h2 class=\"font-syne text-6xl lg:text-7xl tracking-tighter leading-[0.9] mb-10\" data-kid=\"128\">DEPLOYMENT<br data-kid=\"129\"><span class=\"text-gray-600\" data-kid=\"130\">SEQUENCE</span></h2>\n                    <p class=\"font-inter text-gray-400 text-xl leading-relaxed mb-12\" data-kid=\"131\">\n                        Every engagement runs through the same battle-tested four-phase protocol. No improvisation. No agency guesswork. Just a sequence engineered to compound.\n                    </p>\n                    <div class=\"relative rounded-xs overflow-hidden neo-brutal-violet h-[340px] group\" data-kid=\"132\">\n                        <img src=\"https://images.unsplash.com/photo-1678189481940-59df65baf945?auto=format&w=800&q=80&fit=crop\" alt=\"3D purple system blocks\" class=\"w-full h-full object-cover opacity-80 group-hover:scale-105 transition-transform duration-700\" decoding=\"async\" loading=\"lazy\" data-kid=\"133\">\n                        <div class=\"absolute inset-0 bg-gradient-to-t from-[#080C1B] via-transparent to-transparent\" data-kid=\"134\"></div>\n                        <div class=\"absolute bottom-6 left-6 font-mono text-[10px] text-[#B9F6CA] uppercase tracking-widest bg-[#0A1128]/80 px-3 py-2 border border-white/10\" data-kid=\"135\">FIG_01 — SYSTEM BLOCKS INTERLOCKING</div>\n                    </div>\n                </div>\n\n                <div class=\"lg:w-3/5 relative\" data-kid=\"136\">\n                    <div class=\"absolute left-[27px] top-8 bottom-8 w-px bg-gradient-to-b from-[#00E676] via-[#00E676]/40 to-[#7C4DFF]/40 shadow-[0_0_12px_rgba(0,230,118,0.5)]\" data-kid=\"137\"></div>\n                    \n                    <div class=\"space-y-10\" data-kid=\"138\">\n                        <div class=\"flex gap-10 group\" data-kid=\"139\">\n                            <div class=\"w-14 h-14 shrink-0 bg-[#0A1128] border border-[#00E676] flex items-center justify-center rounded-xs relative z-10 shadow-[0_0_20px_rgba(0,230,118,0.3)]\" data-kid=\"140\">\n                                <i class=\"ti ti-radar-2 text-2xl text-[#00E676]\" data-kid=\"141\"></i>\n                            </div>\n                            <div class=\"glass-panel p-10 rounded-xs flex-1 group-hover:border-[#00E676]/40 transition-colors\" data-kid=\"142\">\n                                <div class=\"flex items-center justify-between mb-4\" data-kid=\"143\">\n                                    <span class=\"font-mono text-[10px] text-[#00E676] uppercase tracking-[0.3em]\" data-kid=\"144\">PHASE_01 // RECON</span>\n                                    <span class=\"font-mono text-[9px] text-gray-600\" data-kid=\"145\">WEEK 1</span>\n                                </div>\n                                <h3 class=\"font-syne text-3xl mb-4\" data-kid=\"146\">Deep Market Audit</h3>\n                                <p class=\"font-inter text-gray-400 leading-relaxed\" data-kid=\"147\">Full teardown of your GMB profile, competitor grid scan, keyword demand mapping, and conversion leak diagnosis across your Canadian service area.</p>\n                            </div>\n                        </div>\n\n                        <div class=\"flex gap-10 group\" data-kid=\"148\">\n                            <div class=\"w-14 h-14 shrink-0 bg-[#0A1128] border border-white/20 flex items-center justify-center rounded-xs relative z-10 group-hover:border-[#00E676] transition-colors\" data-kid=\"149\">\n                                <i class=\"ti ti-stack-2 text-2xl text-gray-400 group-hover:text-[#00E676] transition-colors\" data-kid=\"150\"></i>\n                            </div>\n                            <div class=\"glass-panel p-10 rounded-xs flex-1 group-hover:border-[#00E676]/40 transition-colors\" data-kid=\"151\">\n                                <div class=\"flex items-center justify-between mb-4\" data-kid=\"152\">\n                                    <span class=\"font-mono text-[10px] text-[#00E676] uppercase tracking-[0.3em]\" data-kid=\"153\">PHASE_02 // BUILD</span>\n                                    <span class=\"font-mono text-[9px] text-gray-600\" data-kid=\"154\">WEEK 2-3</span>\n                                </div>\n                                <h3 class=\"font-syne text-3xl mb-4\" data-kid=\"155\">System Construction</h3>\n                                <p class=\"font-inter text-gray-400 leading-relaxed\" data-kid=\"156\">GMB optimization stack, campaign architecture, creative angles, conversion tracking, and landing assets — assembled into one interlocked machine.</p>\n                            </div>\n                        </div>\n\n                        <div class=\"flex gap-10 group\" data-kid=\"157\">\n                            <div class=\"w-14 h-14 shrink-0 bg-[#0A1128] border border-white/20 flex items-center justify-center rounded-xs relative z-10 group-hover:border-[#00E676] transition-colors\" data-kid=\"158\">\n                                <i class=\"ti ti-flame text-2xl text-gray-400 group-hover:text-[#00E676] transition-colors\" data-kid=\"159\"></i>\n                            </div>\n                            <div class=\"glass-panel p-10 rounded-xs flex-1 group-hover:border-[#00E676]/40 transition-colors\" data-kid=\"160\">\n                                <div class=\"flex items-center justify-between mb-4\" data-kid=\"161\">\n                                    <span class=\"font-mono text-[10px] text-[#00E676] uppercase tracking-[0.3em]\" data-kid=\"162\">PHASE_03 // IGNITE</span>\n                                    <span class=\"font-mono text-[9px] text-gray-600\" data-kid=\"163\">WEEK 4</span>\n                                </div>\n                                <h3 class=\"font-syne text-3xl mb-4\" data-kid=\"164\">Controlled Launch</h3>\n                                <p class=\"font-inter text-gray-400 leading-relaxed\" data-kid=\"165\">Meta and Google campaigns go live in a learning sprint. Daily signal monitoring, review velocity activation, and bid calibration against live CPL data.</p>\n                            </div>\n                        </div>\n\n                        <div class=\"flex gap-10 group\" data-kid=\"166\">\n                            <div class=\"w-14 h-14 shrink-0 bg-[#0A1128] border border-[#7C4DFF]/60 flex items-center justify-center rounded-xs relative z-10 shadow-[0_0_20px_rgba(124,77,255,0.25)]\" data-kid=\"167\">\n                                <i class=\"ti ti-chart-arrows-vertical text-2xl text-[#7C4DFF]\" data-kid=\"168\"></i>\n                            </div>\n                            <div class=\"glass-panel p-10 rounded-xs flex-1 group-hover:border-[#7C4DFF]/40 transition-colors\" data-kid=\"169\">\n                                <div class=\"flex items-center justify-between mb-4\" data-kid=\"170\">\n                                    <span class=\"font-mono text-[10px] text-[#7C4DFF] uppercase tracking-[0.3em]\" data-kid=\"171\">PHASE_04 // EXPAND</span>\n                                    <span class=\"font-mono text-[9px] text-gray-600\" data-kid=\"172\">MONTH 2+</span>\n                                </div>\n                                <h3 class=\"font-syne text-3xl mb-4\" data-kid=\"173\">Scale & Lock Out</h3>\n                                <p class=\"font-inter text-gray-400 leading-relaxed\" data-kid=\"174\">Budget scales into proven winners. Geo-radius expands city by city while ranking grid defense locks competitors out of your captured territory.</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"relative h-[560px] overflow-hidden bg-[#050812]\" data-kid=\"175\">\n        <video src=\"https://videos.pexels.com/video-files/29397255/12662082_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/29397255/abstract-animation-colorful-neon-gradient-background-29397255.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"absolute inset-0 w-full h-full object-cover opacity-50 mix-blend-screen\" data-kid=\"176\"></video>\n        <div class=\"absolute inset-0 bg-gradient-to-b from-[#0A1128] via-transparent to-[#0A1128]\" data-kid=\"177\"></div>\n        <div class=\"relative z-10 h-full max-w-7xl mx-auto px-12 lg:px-24 flex flex-col justify-center items-center text-center\" data-kid=\"178\">\n            <span class=\"font-mono text-[10px] text-[#B9F6CA] uppercase tracking-[0.4em] mb-8 px-4 py-2 border border-white/10 bg-[#0A1128]/60 backdrop-blur-sm\" data-kid=\"179\">LIVE DATA FIELD — NORTHERN GRID</span>\n            <h2 class=\"font-syne text-5xl lg:text-7xl tracking-tighter leading-[0.95] mb-10 max-w-4xl\" data-kid=\"180\">YOUR MARKET MOVES LIKE WEATHER.<br data-kid=\"181\"><span class=\"text-transparent bg-clip-text bg-gradient-to-r from-[#00E676] to-[#7C4DFF]\" data-kid=\"182\">WE FORECAST IT.</span></h2>\n            <div class=\"flex flex-wrap justify-center gap-6\" data-kid=\"183\">\n                <div class=\"glass-panel px-8 py-5 rounded-xs flex items-center gap-4\" data-kid=\"184\">\n                    <i class=\"ti ti-activity text-[#00E676] text-2xl\" data-kid=\"185\"></i>\n                    <div class=\"text-left\" data-kid=\"186\">\n                        <div class=\"font-syne text-xl leading-none\" data-kid=\"187\">2.4M+</div>\n                        <div class=\"font-mono text-[8px] text-gray-500 uppercase tracking-widest mt-1\" data-kid=\"188\">Signals Processed / Day</div>\n                    </div>\n                </div>\n                <div class=\"glass-panel px-8 py-5 rounded-xs flex items-center gap-4\" data-kid=\"189\">\n                    <i class=\"ti ti-clock-bolt text-[#7C4DFF] text-2xl\" data-kid=\"190\"></i>\n                    <div class=\"text-left\" data-kid=\"191\">\n                        <div class=\"font-syne text-xl leading-none\" data-kid=\"192\">&lt; 6 HRS</div>\n                        <div class=\"font-mono text-[8px] text-gray-500 uppercase tracking-widest mt-1\" data-kid=\"193\">Trend Reaction Time</div>\n                    </div>\n                </div>\n                <div class=\"glass-panel px-8 py-5 rounded-xs flex items-center gap-4\" data-kid=\"194\">\n                    <i class=\"ti ti-shield-lock text-[#B9F6CA] text-2xl\" data-kid=\"195\"></i>\n                    <div class=\"text-left\" data-kid=\"196\">\n                        <div class=\"font-syne text-xl leading-none\" data-kid=\"197\">24/7</div>\n                        <div class=\"font-mono text-[8px] text-gray-500 uppercase tracking-widest mt-1\" data-kid=\"198\">Grid Defense Active</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-12 lg:px-24 bg-[#080C1B] relative overflow-hidden\" data-kid=\"199\">\n        <div class=\"absolute inset-0 aurora-glow\" data-kid=\"200\"></div>\n        <div class=\"max-w-7xl mx-auto relative z-10\" data-kid=\"201\">\n            <div class=\"text-center mb-24\" data-kid=\"202\">\n                <h2 class=\"font-syne text-6xl lg:tex