white/2 hover:border-[#00E676]/30 transition-colors group\" data-kid=\"219\">\n                            <div class=\"text-[10px] text-gray-500 font-mono uppercase tracking-[0.2em] mb-6 block\" data-kid=\"220\">Est. Monthly Leads</div>\n                            <div class=\"text-6xl font-syne text-[#00E676] tracking-tighter group-hover:scale-105 transition-transform origin-left\" data-kid=\"221\">412<span class=\"text-xl ml-1 text-gray-600\" data-kid=\"222\">+</span></div>\n                        </div>\n                        <div class=\"p-10 border border-white/5 bg-white/2 hover:border-[#00E676]/30 transition-colors group\" data-kid=\"223\">\n                            <div class=\"text-[10px] text-gray-500 font-mono uppercase tracking-[0.2em] mb-6 block\" data-kid=\"224\">Avg. Cost Per Lead</div>\n                            <div class=\"text-6xl font-syne text-[#00E676] tracking-tighter group-hover:scale-105 transition-transform origin-left\" data-kid=\"225\">$12.40</div>\n                        </div>\n                        <div class=\"p-10 border border-white/5 bg-white/2 hover:border-[#00E676]/30 transition-colors group\" data-kid=\"226\">\n                            <div class=\"text-[10px] text-gray-500 font-mono uppercase tracking-[0.2em] mb-6 block\" data-kid=\"227\">Projected Net ROI</div>\n                            <div class=\"text-6xl font-syne text-[#00E676] tracking-tighter group-hover:scale-105 transition-transform origin-left\" data-kid=\"228\">840<span class=\"text-xl ml-1 text-gray-600\" data-kid=\"229\">%</span></div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-12 lg:px-24 bg-[#0A1128] relative\" data-kid=\"230\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"231\">\n            <div class=\"flex flex-col md:flex-row md:items-end justify-between gap-12 mb-20\" data-kid=\"232\">\n                <div data-kid=\"233\">\n                    <span class=\"text-[#7C4DFF] font-mono text-xs uppercase tracking-[0.3em] mb-4 block\" data-kid=\"234\">Verticals In Scope</span>\n                    <h2 class=\"font-syne text-6xl lg:text-7xl tracking-tighter leading-[0.9]\" data-kid=\"235\">SECTOR<br data-kid=\"236\"><span class=\"text-gray-600\" data-kid=\"237\">TARGETS</span></h2>\n                </div>\n                <p class=\"font-inter text-gray-400 max-w-md text-lg leading-relaxed\" data-kid=\"238\">\n                    We specialize in high-ticket Canadian service categories where one captured lead pays for the entire month.\n                </p>\n            </div>\n\n            <div class=\"grid grid-cols-2 lg:grid-cols-3 gap-6\" data-kid=\"239\">\n                <div class=\"sector-tile border border-white/10 bg-[#101820]/60 p-12 rounded-xs flex flex-col items-start gap-8 cursor-default\" data-kid=\"240\">\n                    <i class=\"ti ti-air-conditioning sector-icon text-5xl text-gray-500 transition-all\" data-kid=\"241\"></i>\n                    <div data-kid=\"242\">\n                        <div class=\"sector-label font-syne text-2xl tracking-tight transition-colors\" data-kid=\"243\">HVAC</div>\n                        <div class=\"font-mono text-[9px] text-gray-600 uppercase tracking-[0.25em] mt-2\" data-kid=\"244\">SECTOR_01 // AVG TICKET $8K</div>\n                    </div>\n                </div>\n                <div class=\"sector-tile border border-white/10 bg-[#101820]/60 p-12 rounded-xs flex flex-col items-start gap-8 cursor-default\" data-kid=\"245\">\n                    <i class=\"ti ti-home-bolt sector-icon text-5xl text-gray-500 transition-all\" data-kid=\"246\"></i>\n                    <div data-kid=\"247\">\n                        <div class=\"sector-label font-syne text-2xl tracking-tight transition-colors\" data-kid=\"248\">ROOFING</div>\n                        <div class=\"font-mono text-[9px] text-gray-600 uppercase tracking-[0.25em] mt-2\" data-kid=\"249\">SECTOR_02 // AVG TICKET $14K</div>\n                    </div>\n                </div>\n                <div class=\"sector-tile border border-white/10 bg-[#101820]/60 p-12 rounded-xs flex flex-col items-start gap-8 cursor-default\" data-kid=\"250\">\n                    <i class=\"ti ti-dental sector-icon text-5xl text-gray-500 transition-all\" data-kid=\"251\"></i>\n                    <div data-kid=\"252\">\n                        <div class=\"sector-label font-syne text-2xl tracking-tight transition-colors\" data-kid=\"253\">DENTAL</div>\n                        <div class=\"font-mono text-[9px] text-gray-600 uppercase tracking-[0.25em] mt-2\" data-kid=\"254\">SECTOR_03 // AVG LTV $6K</div>\n                    </div>\n                </div>\n                <div class=\"sector-tile border border-white/10 bg-[#101820]/60 p-12 rounded-xs flex flex-col items-start gap-8 cursor-default\" data-kid=\"255\">\n                    <i class=\"ti ti-scale sector-icon text-5xl text-gray-500 transition-all\" data-kid=\"256\"></i>\n                    <div data-kid=\"257\">\n                        <div class=\"sector-label font-syne text-2xl tracking-tight transition-colors\" data-kid=\"258\">LEGAL</div>\n                        <div class=\"font-mono text-[9px] text-gray-600 uppercase tracking-[0.25em] mt-2\" data-kid=\"259\">SECTOR_04 // AVG CASE $11K</div>\n                    </div>\n                </div>\n                <div class=\"sector-tile border border-white/10 bg-[#101820]/60 p-12 rounded-xs flex flex-col items-start gap-8 cursor-default\" data-kid=\"260\">\n                    <i class=\"ti ti-building-skyscraper sector-icon text-5xl text-gray-500 transition-all\" data-kid=\"261\"></i>\n                    <div data-kid=\"262\">\n                        <div class=\"sector-label font-syne text-2xl tracking-tight transition-colors\" data-kid=\"263\">REAL ESTATE</div>\n                        <div class=\"font-mono text-[9px] text-gray-600 uppercase tracking-[0.25em] mt-2\" data-kid=\"264\">SECTOR_05 // AVG COMM $19K</div>\n                    </div>\n                </div>\n                <div class=\"sector-tile border border-white/10 bg-[#101820]/60 p-12 rounded-xs flex flex-col items-start gap-8 cursor-default\" data-kid=\"265\">\n                    <i class=\"ti ti-car sector-icon text-5xl text-gray-500 transition-all\" data-kid=\"266\"></i>\n                    <div data-kid=\"267\">\n                        <div class=\"sector-label font-syne text-2xl tracking-tight transition-colors\" data-kid=\"268\">AUTO</div>\n                        <div class=\"font-mono text-[9px] text-gray-600 uppercase tracking-[0.25em] mt-2\" data-kid=\"269\">SECTOR_06 // AVG REPAIR $2.4K</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    \n        <div class=\"absolute inset-0 aurora-violet opacity-50\" data-kid=\"270\"></div>\n        \n            <div class=\"w-full lg:w-1/2 relative h-[600px] flex items-center justify-center\" data-kid=\"271\">\n                <svg class=\"absolute inset-0 w-full h-full pointer-events-none opacity-50\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 700 600\" preserveAspectRatio=\"xMidYMid meet\" data-kid=\"272\">\n                    <line x1=\"350\" y1=\"300\" x2=\"520\" y2=\"100\" stroke=\"#7C4DFF\" stroke-width=\"1\" stroke-dasharray=\"6 6\" class=\"dash-flow\" data-kid=\"273\"></line>\n                    <line x1=\"350\" y1=\"300\" x2=\"140\" y2=\"450\" stroke=\"#00E676\" stroke-width=\"1\" stroke-dasharray=\"6 6\" class=\"dash-flow\" data-kid=\"274\"></line>\n                    <line x1=\"350\" y1=\"300\" x2=\"100\" y2=\"220\" stroke=\"#ffffff\" stroke-opacity=\"0.2\" stroke-width=\"1\" stroke-dasharray=\"4 8\" data-kid=\"275\"></line>\n                </svg>\n\n                </div>\n                    <i class=\"ti ti-building-store text-6xl text-[#0A1128]\" data-kid=