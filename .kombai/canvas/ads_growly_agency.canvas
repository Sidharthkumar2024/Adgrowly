      "html": "<div class=\"bg-[#F4F7F6] text-[#111111] font-inter selection:bg-[#E53935] selection:text-white\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .font-inter { font-family: 'Inter', sans-serif; }\n\n        .glass {\n            background: rgba(255, 255, 255, 0.45);\n            backdrop-filter: blur(16px);\n            -webkit-backdrop-filter: blur(16px);\n            border: 1px solid rgba(255, 255, 255, 0.4);\n        }\n\n        .glass-dark {\n            background: rgba(17, 17, 17, 0.8);\n            backdrop-filter: blur(12px);\n            -webkit-backdrop-filter: blur(12px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        .shadow-soft {\n            box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.05);\n        }\n\n        .shadow-glass {\n            box-shadow: 0 20px 50px -15px rgba(31, 38, 135, 0.08);\n        }\n\n        input[type='range'] {\n            -webkit-appearance: none;\n            width: 100%;\n            height: 6px;\n            background: #e2e8f0;\n            border-radius: 5px;\n            outline: none;\n        }\n\n        input[type='range']::-webkit-slider-thumb {\n            -webkit-appearance: none;\n            appearance: none;\n            width: 28px;\n            height: 28px;\n            background: #E53935;\n            cursor: pointer;\n            border-radius: 50%;\n            border: 4px solid white;\n            box-shadow: 0 4px 15px rgba(229, 57, 53, 0.3);\n            transition: transform 0.2s ease;\n        }\n\n        input[type='range']::-webkit-slider-thumb:hover {\n            transform: scale(1.1);\n        }\n\n        /* 3D tilt system */\n        .tilt-wrap { perspective: 1200px; }\n        .bento-card {\n            transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);\n            transform-style: preserve-3d;\n        }\n        .bento-card:hover {\n            transform: rotateX(4deg) rotateY(-4deg) translateY(-6px);\n            box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.12);\n        }\n        .tilt-right:hover {\n            transform: rotateX(4deg) rotateY(4deg) translateY(-6px);\n        }\n\n        @keyframes floaty {\n            0%, 100% { transform: translateY(0) rotate(-3deg); }\n            50% { transform: translateY(-16px) rotate(-1deg); }\n        }\n        .animate-floaty { animation: floaty 7s ease-in-out infinite; }\n\n        @keyframes floaty2 {\n            0%, 100% { transform: translateY(0); }\n            50% { transform: translateY(-10px); }\n        }\n        .animate-floaty2 { animation: floaty2 5s ease-in-out infinite; }\n\n        details.faq-row summary::-webkit-details-marker { display: none; }\n        details.faq-row[open] .faq-chevron { transform: rotate(180deg); }\n        .faq-chevron { transition: transform 0.3s ease; }\n    </style>\n\n    \n    <nav class=\"relative w-full z-50 px-10 py-10 flex justify-between items-center bg-white/30 backdrop-blur-xs\" data-kid=\"2\">\n        <div class=\"flex items-center gap-3\" data-kid=\"3\">\n            \n            <svg width=\"44\" height=\"44\" viewBox=\"0 0 48 48\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" class=\"drop-shadow-[0_8px_16px_rgba(229,57,53,0.35)]\" data-kid=\"4\">\n                <rect width=\"48\" height=\"48\" rx=\"13\" fill=\"#E53935\" data-kid=\"5\"></rect>\n                <rect width=\"48\" height=\"48\" rx=\"13\" fill=\"url(#lg1)\" fill-opacity=\"0.25\" data-kid=\"6\"></rect>\n                <defs data-kid=\"7\">\n                    <linearGradient id=\"lg1\" x1=\"0\" y1=\"0\" x2=\"48\" y2=\"48\" gradientUnits=\"userSpaceOnUse\" data-kid=\"8\">\n                        <stop stop-color=\"white\" data-kid=\"9\"></stop>\n                        <stop offset=\"1\" stop-color=\"white\" stop-opacity=\"0\" data-kid=\"10\"></stop>\n                    </linearGradient>\n                </defs>\n                \n                <rect x=\"9\" y=\"29\" width=\"5.5\" height=\"10\" rx=\"2\" fill=\"white\" fill-opacity=\"0.45\" data-kid=\"11\"></rect>\n                <rect x=\"18\" y=\"24\" width=\"5.5\" height=\"15\" rx=\"2\" fill=\"white\" fill-opacity=\"0.65\" data-kid=\"12\"></rect>\n                <rect x=\"27\" y=\"19\" width=\"5.5\" height=\"20\" rx=\"2\" fill=\"white\" fill-opacity=\"0.85\" data-kid=\"13\"></rect>\n                \n                <path d=\"M10 26 L22 17.5 L27 21 L36 12.5\" stroke=\"white\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\" data-kid=\"14\"></path>\n                \n                <path d=\"M37.2 6.2 L38.1 8.2 L39.6 7.5 L39.3 9.2 L41.2 9.5 L39.9 10.9 L41.5 11.9 L39.7 12.5 L40.2 14.2 L38.4 13.7 L38.1 15.7 L37.2 14.4 L36.3 15.7 L36 13.7 L34.2 14.2 L34.7 12.5 L32.9 11.9 L34.5 10.9 L33.2 9.5 L35.1 9.2 L34.8 7.5 L36.3 8.2 Z\" fill=\"white\" data-kid=\"15\"></path>\n            </svg>\n            <span class=\"text-2xl font-extrabold tracking-tighter text-[#111111]\" data-kid=\"16\">Ads growly<span class=\"text-[#E53935]\" data-kid=\"17\">.</span></span>\n        </div>\n        <div class=\"hidden md:flex items-center gap-10\" data-kid=\"18\">\n            <a href=\"#\" class=\"text-sm font-semibold text-slate-600 hover:text-[#111111] transition-colors\" data-kid=\"19\">Our Systems</a>\n            <a href=\"#\" class=\"text-sm font-semibold text-slate-600 hover:text-[#111111] transition-colors\" data-kid=\"20\">GMB Engine</a>\n            <a href=\"#\" class=\"text-sm font-semibold text-slate-600 hover:text-[#111111] transition-colors\" data-kid=\"21\">Pricing</a>\n            <a href=\"#\" class=\"text-sm font-semibold text-slate-600 hover:text-[#111111] transition-colors\" data-kid=\"22\">Success Stories</a>\n        </div>\n        <button class=\"glass px-8 py-3.5 rounded-2xl text-sm font-bold shadow-soft hover:bg-white transition-all border-slate-200/50\" data-kid=\"23\">\n            Audit Your Brand\n        </button>\n    </nav>\n\n    \n    <section class=\"relative pt-32 pb-32 px-6 flex flex-col items-center\" data-kid=\"24\">\n        <div class=\"max-w-4xl text-center z-10\" data-kid=\"25\">\n            <div class=\"inline-flex items-center gap-2 px-5 py-2 rounded-full bg-white border border-slate-100 shadow-soft mb-10\" data-kid=\"26\">\n                <span class=\"w-2 h-2 rounded-full bg-[#E53935] animate-pulse\" data-kid=\"27\"></span>\n                <span class=\"text-[10px] font-black uppercase tracking-[0.15em] text-slate-500\" data-kid=\"28\">Engineered for Canada's Top Service Brands</span>\n            </div>\n            <h1 class=\"text-[4.5rem] md:text-[6rem] font-black text-[#111111] leading-[0.9] tracking-tighter mb-10\" data-kid=\"29\">\n                Growth Systems for <br data-kid=\"30\">\n                <span class=\"text-[#1E88E5]\" data-kid=\"31\">Service Dominance.</span>\n            </h1>\n            <p class=\"text-xl text-slate-500 max-w-2xl mx-auto leading-relaxed mb-12\" data-kid=\"32\">\n                We build precision ad funnels and local SEO engines that turn Google searches into booked appointments for high-intent providers.\n            </p>\n            <div class=\"flex flex-col sm:flex-row gap-4 justify-center\" data-kid=\"33\">\n                <button class=\"bg-[#111111] text-white px-10 py-5 rounded-2xl font-bold shadow-xl hover:scale-105 transition-transform\" data-kid=\"34\">Get Started Today</button>\n                <button class=\"glass text-[#111111] px-10 py-5 rounded-2xl font-bold shadow-soft hover:bg-white transition-all\" data-kid=\"35\">View Our Work</button>\n            </div>\n        </div>\n\n        \n        <div class=\"w-full max-w-7xl mt-12 relative px-4\" data-kid=\"36\">\n            <div class=\"glass p-4 rounded-[2.5rem] shadow-glass relative overflow-hidden aspect-[16/8] md:aspect-[21/9]\" data-kid=\"37\">\n                <div class=\"w-full h-full rounded-[1.5rem] overflow-hidden relative border border-slate-200/50 bg-[#EAF1F7]\" data-kid=\"38\">\n                    <video src=\"https://videos.pexels.com/video-files/16655800/16655800-hd_1080_1920_30fps.mp4\" poster=\"https://images.pexels.com/videos/16655800/3d-color-digital-fractal-16655800.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=1200&w=630\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover brightness-105 saturate-[1.05]\" data-kid=\"39\">\n                    </video>\n\n                    <div class=\"absolute top-10 left-10 glass p-5 rounded-2xl flex items-center gap-5 shadow-2xl border-white/60\" data-kid=\"40\">\n                        <div class=\"w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-inner\" data-kid=\"41\">\n                            <i class=\"ti ti-brand-google-filled text-[#4285F4] text-3xl\" data-kid=\"42\"></i>\n                        </div>\n                        <div data-kid=\"43\">\n                            <div class=\"text-[10px] text-slate-500 uppercase font-black tracking-widest\" data-kid=\"44\">Local Rank</div>\n                            <div class=\"text-2xl font-black\" data-kid=\"45\">Top 3 Pack</div>\n                            <div class=\"flex gap-0.5 text-[#FBBC05] mt-0.5\" data-kid=\"46\">\n                                <i class=\"ti ti-star-filled text-xs\" data-kid=\"47\"></i><i class=\"ti ti-star-filled text-xs\" data-kid=\"48\"></i><i class=\"ti ti-star-filled text-xs\" data-kid=\"49\"></i><i class=\"ti ti-star-filled text-xs\" data-kid=\"50\"></i><i class=\"ti ti-star-filled text-xs\" data-kid=\"51\"></i>\n                            </div>\n                        </div>\n                    </div>\n\n                    <div class=\"absolute bottom-10 right-10 glass p-5 rounded-2xl flex items-center gap-5 shadow-2xl border-white/60\" data-kid=\"52\">\n                        <div class=\"w-14 h-14 bg-white rounded-2xl flex items-center justify-center shadow-inner\" data-kid=\"53\">\n                            <i class=\"ti ti-trending-up text-[#E53935] text-3xl\" data-kid=\"54\"></i>\n                        </div>\n                        <div data-kid=\"55\">\n                            <div class=\"text-[10px] text-slate-500 uppercase font-black tracking-widest\" data-kid=\"56\">Meta ROAS</div>\n                            <div class=\"text-2xl font-black\" data-kid=\"57\">4.82x Avg.</div>\n                            <div class=\"text-[10px] font-bold text-green-600 mt-0.5\" data-kid=\"58\">+22% MoM Increase</div>\n                        </div>\n                    </div>\n\n                    <div class=\"absolute top-10 right-10 glass px-5 py-3 rounded-2xl shadow-2xl border-white/60 flex items-center gap-3 animate-floaty2\" data-kid=\"59\">\n                        <i class=\"ti ti-map-pin-filled text-[#E53935] text-xl\" data-kid=\"60\"></i>\n                        <div data-kid=\"61\">\n                            <div class=\"text-[9px] text-slate-500 uppercase font-black tracking-widest\" data-kid=\"62\">Serving</div>\n                            <div class=\"text-sm font-black\" data-kid=\"63\">Toronto · Vancouver · Calgary</div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"absolute -top-20 -left-20 w-80 h-80 bg-blue-100 rounded-full blur-[100px] -z-10 opacity-60\" data-kid=\"64\"></div>\n            <div class=\"absolute -bottom-20 -right-20 w-80 h-80 bg-red-100 rounded-full blur-[100px] -z-10 opacity-40\" data-kid=\"65\"></div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6 bg-white\" data-kid=\"66\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"67\">\n            <div class=\"flex flex-col md:flex-row justify-between items-end mb-16 gap-6\" data-kid=\"68\">\n                <div class=\"max-w-xl\" data-kid=\"69\">\n                    <span class=\"text-[#E53935] font-black uppercase text-xs tracking-widest mb-4 block\" data-kid=\"70\">The Toolkit</span>\n                    <h2 class=\"text-5xl font-bold leading-tight\" data-kid=\"71\">Everything you need to <span class=\"text-slate-400 font-medium italic\" data-kid=\"72\">own the market.</span></h2>\n                </div>\n                <div class=\"pb-2\" data-kid=\"73\">\n                    <p class=\"text-slate-500 font-medium\" data-kid=\"74\">Full-funnel execution across Canada's most critical <br data-kid=\"75\">customer touchpoints.</p>\n                </div>\n            </div>\n\n            <div class=\"tilt-wrap grid grid-cols-1 md:grid-cols-4 gap-6 auto-rows-[340px]\" data-kid=\"76\">\n                \n                <div class=\"md:col-span-2 md:row-span-2 bento-card rounded-[3.5rem] bg-gradient-to-br from-[#F4F7F6] to-white p-14 flex flex-col justify-between overflow-hidden relative border border-slate-100/50\" data-kid=\"77\">\n                    <div class=\"z-10 relative\" data-kid=\"78\">\n                        <div class=\"inline-flex px-3 py-1 bg-[#1E88E5]/10 rounded-full border border-[#1E88E5]/20 mb-6\" data-kid=\"79\">\n                            <span class=\"text-[10px] font-black uppercase tracking-tighter text-[#1E88E5]\" data-kid=\"80\">Google Business Profile</span>\n                        </div>\n                        <h3 class=\"text-4xl font-bold mb-6\" data-kid=\"81\">The AI-Powered <br data-kid=\"82\">Local Engine.</h3>\n                        <p class=\"text-slate-500 text-lg leading-relaxed max-w-sm\" data-kid=\"83\">\n                            We don't just manage your GMB; we weaponize it. Automatic review responses, localized posts, and Rank Tracking.\n                        </p>\n                    </div>\n\n                    <div class=\"absolute -right-6 -bottom-10 w-72 h-[480px] bg-white rounded-[3.5rem] shadow-[0_30px_60px_-15px_rgba(0,0,0,0.3)] border-[10px] border-[#111111] rotate-[-5deg] p-4 flex flex-col gap-4 transition-all hover:rotate-0 hover:-translate-y-2 duration-700\" data-kid=\"84\">\n                        <div class=\"w-1/3 h-6 bg-slate-50 rounded-full mx-auto mt-2\" data-kid=\"85\"></div>\n                        <div class=\"w-full h-32 bg-slate-50 rounded-2xl relative overflow-hidden border border-slate-100\" data-kid=\"86\">\n                             <div class=\"absolute inset-0 bg-blue-50/50\" data-kid=\"87\"></div>\n                             <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"88\">\n                                <i class=\"ti ti-map-pin-filled text-blue-500 text-4xl drop-shadow-sm\" data-kid=\"89\"></i>\n                             </div>\n                             <div class=\"absolute inset-0 opacity-10 pointer-events-none\" data-kid=\"90\">\n                                <div class=\"absolute top-1/2 left-0 w-full h-[1px] bg-slate-400 rotate-12\" data-kid=\"91\"></div>\n                                <div class=\"absolute top-0 left-1/2 w-[1px] h-full bg-slate-400 -rotate-12\" data-kid=\"92\"></div>\n                             </div>\n                        </div>\n                        <div class=\"space-y-4 px-2\" data-kid=\"93\">\n                            <div class=\"flex justify-between items-start\" data-kid=\"94\">\n                                <div class=\"h-5 w-3/4 bg-slate-900 rounded-lg\" data-kid=\"95\"></div>\n                                <div class=\"h-5 w-8 bg-blue-100 rounded-lg\" data-kid=\"96\"></div>\n                            </div>\n                            <div class=\"flex items-center gap-2\" data-kid=\"97\">\n                                <div class=\"flex gap-0.5 text-[#FBBC05]\" data-kid=\"98\"><i class=\"ti ti-star-filled text-[10px]\" data-kid=\"99\"></i><i class=\"ti ti-star-filled text-[10px]\" data-kid=\"100\"></i><i class=\"ti ti-star-filled text-[10px]\" data-kid=\"101\"></i><i class=\"ti ti-star-filled text-[10px]\" data-kid=\"102\"></i><i class=\"ti ti-star-filled text-[10px]\" data-kid=\"103\"></i></div>\n                                <span class=\"text-[10px] font-bold text-slate-400\" data-kid=\"104\">4.9 (124)</span>\n                            </div>\n                            <div class=\"flex gap-3\" data-kid=\"105\">\n                                <div class=\"h-10 w-10 bg-blue-600 rounded-full flex items-center justify-center shadow-lg shadow-blue-200\" data-kid=\"106\"><i class=\"ti ti-phone-filled text-white text-lg\" data-kid=\"107\"></i></div>\n                                <div class=\"h-10 grow bg-slate-50 border border-slate-100 rounded-full flex items-center px-4\" data-kid=\"108\">\n                                    <div class=\"h-2 w-1/2 bg-slate-200 rounded\" data-kid=\"109\"></div>\n                                </div>\n                            </div>\n                            <div class=\"space-y-2 pt-2 border-t border-slate-50\" data-kid=\"110\">\n                                <div class=\"flex justify-between\" data-kid=\"111\"><div class=\"h-2 w-1/3 bg-slate-100 rounded\" data-kid=\"112\"></div><div class=\"h-2 w-1/4 bg-slate-100 rounded\" data-kid=\"113\"></div></div>\n                                <div class=\"h-2 w-full bg-slate-50 rounded\" data-kid=\"114\"></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"md:col-span-2 bento-card tilt-right rounded-[3.5rem] bg-gradient-to-br from-purple-50 to-pink-50 p-10 flex flex-col justify-center relative border border-purple-100 overflow-hidden\" data-kid=\"115\">\n                    <div class=\"absolute -top-10 -right-10 w-40 h-40 bg-purple-200/30 rounded-full blur-3xl\" data-kid=\"116\"></div>\n                    <div class=\"relative z-10\" data-kid=\"117\">\n                        <i class=\"ti ti-player-play-filled text-4xl text-purple-600 mb-6 block\" data-kid=\"118\"></i>\n                        <h3 class=\"text-2xl font-bold mb-3\" data-kid=\"119\">Scroll-Stopping Meta Creative</h3>\n                        <p class=\"text-slate-600\" data-kid=\"120\">UGC-style assets and static creatives engineered for local attention and 3x industry conversion rates.</p>\n                        <div class=\"mt-8 flex items-center gap-3\" data-kid=\"121\">\n                            <div class=\"flex -space-x-2\" data-kid=\"122\">\n                                <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"Client avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"123\">\n                                <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"Client avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"124\">\n                                <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"Client avatar\" decoding=\"async\" loading=\"lazy\" data-kid=\"125\">\n                            </div>\n                            <span class=\"text-xs font-bold text-slate-400\" data-kid=\"126\">Used by 40+ Top Brands</span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"bento-card rounded-[3.5rem] bg-[#111111] p-10 flex flex-col justify-between text-white border border-slate-800\" data-kid=\"127\">\n                    <i class=\"ti ti-search text-4xl text-[#E53935]\" data-kid=\"128\"></i>\n                    <div data-kid=\"129\">\n                        <h3 class=\"text-2xl font-bold mb-2 leading-tight\" data-kid=\"130\">High-Intent Capture</h3>\n                        <p class=\"text-slate-400 text-sm\" data-kid=\"131\">Snatching customers exactly when they need you most.</p>\n                    </div>\n                </div>\n\n                \n                <div class=\"bento-card tilt-right rounded-[3.5rem] bg-[#F4F7F6] p-10 flex flex-col justify-between border border-slate-100\" data-kid=\"132\">\n                    <i class=\"ti ti-refresh text-4xl text-slate-400\" data-kid=\"133\"></i>\n                    <div data-kid=\"134\">\n                        <h3 class=\"text-2xl font-bold mb-2 leading-tight\" data-kid=\"135\">Keep the lights on.</h3>\n                        <p class=\"text-slate-500 text-sm\" data-kid=\"136\">24/7 Monitoring, testing, and proactive optimization.</p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6 bg-[#F4F7F6] relative overflow-hidden\" data-kid=\"137\">\n        <div class=\"absolute top-0 right-0 w-96 h-96 bg-blue-100/60 rounded-full blur-[120px]\" data-kid=\"138\"></div>\n        <div class=\"max-w-7xl mx-auto relative z-10\" data-kid=\"139\">\n            <div class=\"text-center mb-20\" data-kid=\"140\">\n                <span class=\"text-[#E53935] font-black uppercase text-xs tracking-widest mb-4 block\" data-kid=\"141\">The Flight Plan</span>\n                <h2 class=\"text-6xl font-black tracking-tighter mb-6\" data-kid=\"142\">How we launch in <span class=\"text-[#1E88E5]\" data-kid=\"143\">14 days.</span></h2>\n                <p class=\"text-xl text-slate-500 max-w-2xl mx-auto font-medium\" data-kid=\"144\">A proven 4-step sprint that takes you from invisible to unavoidable in your local Canadian market.</p>\n            </div>\n\n            <div class=\"grid grid-cols-1 md:grid-cols-4 gap-6 relative\" data-kid=\"145\">\n                \n                <div class=\"hidden md:block absolute top-[88px] left-[12%] right-[12%] h-[2px] bg-gradient-to-r from-[#E53935]/30 via-[#1E88E5]/30 to-[#E53935]/30\" data-kid=\"146\"></div>\n\n                <div class=\"glass rounded-[2.5rem] p-10 shadow-glass relative border-white/60 hover:-translate-y-2 transition-transform duration-500\" data-kid=\"147\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[#E53935] text-white flex items-center justify-center font-black text-xl shadow-lg shadow-red-200 mb-8 relative z-10\" data-kid=\"148\">01</div>\n                    <i class=\"ti ti-zoom-scan text-4xl text-[#1E88E5] mb-5 block\" data-kid=\"149\"></i>\n                    <h3 class=\"text-2xl font-bold mb-3\" data-kid=\"150\">Audit</h3>\n                    <p class=\"text-slate-500 leading-relaxed text-sm\" data-kid=\"151\">Deep teardown of your GMB, ads history, competitors, and zip-code demand. We find the leaks before spending a dollar.</p>\n                    <div class=\"mt-6 text-[10px] font-black uppercase tracking-widest text-slate-400\" data-kid=\"152\">Days 1–3</div>\n                </div>\n\n                <div class=\"glass rounded-[2.5rem] p-10 shadow-glass relative border-white/60 hover:-translate-y-2 transition-transform duration-500\" data-kid=\"153\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[#E53935] text-white flex items-center justify-center font-black text-xl shadow-lg shadow-red-200 mb-8 relative z-10\" data-kid=\"154\">02</div>\n                    <i class=\"ti ti-tools text-4xl text-[#1E88E5] mb-5 block\" data-kid=\"155\"></i>\n                    <h3 class=\"text-2xl font-bold mb-3\" data-kid=\"156\">Build</h3>\n                    <p class=\"text-slate-500 leading-relaxed text-sm\" data-kid=\"157\">Landing pages, tracking, creative angles, GMB optimization, and CRM routing — assembled into one connected system.</p>\n                    <div class=\"mt-6 text-[10px] font-black uppercase tracking-widest text-slate-400\" data-kid=\"158\">Days 4–9</div>\n                </div>\n\n                <div class=\"glass rounded-[2.5rem] p-10 shadow-glass relative border-white/60 hover:-translate-y-2 transition-transform duration-500\" data-kid=\"159\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[#E53935] text-white flex items-center justify-center font-black text-xl shadow-lg shadow-red-200 mb-8 relative z-10\" data-kid=\"160\">03</div>\n                    <i class=\"ti ti-rocket text-4xl text-[#1E88E5] mb-5 block\" data-kid=\"161\"></i>\n                    <h3 class=\"text-2xl font-bold mb-3\" data-kid=\"162\">Launch</h3>\n                    <p class=\"text-slate-500 leading-relaxed text-sm\" data-kid=\"163\">Meta + Google campaigns go live with conservative bids. Every call, form, and direction request is tracked from minute one.</p>\n                    <div class=\"mt-6 text-[10px] font-black uppercase tracking-widest text-slate-400\" data-kid=\"164\">Days 10–14</div>\n                </div>\n\n                <div class=\"glass rounded-[2.5rem] p-10 shadow-glass relative border-white/60 hover:-translate-y-2 transition-transform duration-500\" data-kid=\"165\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[#111111] text-white flex items-center justify-center font-black text-xl shadow-lg mb-8 relative z-10\" data-kid=\"166\">04</div>\n                    <i class=\"ti ti-chart-arrows-vertical text-4xl text-[#E53935] mb-5 block\" data-kid=\"167\"></i>\n                    <h3 class=\"text-2xl font-bold mb-3\" data-kid=\"168\">Scale</h3>\n                    <p class=\"text-slate-500 leading-relaxed text-sm\" data-kid=\"169\">Weekly learning loops. Winning angles get budget; losers get cut. Your cost per booked job drops month over month.</p>\n                    <div class=\"mt-6 text-[10px] font-black uppercase tracking-widest text-[#E53935]\" data-kid=\"170\">Ongoing</div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6 bg-white overflow-hidden\" data-kid=\"171\">\n        <div class=\"max-w-6xl mx-auto\" data-kid=\"172\">\n            <div class=\"grid md:grid-cols-2 gap-12 items-center\" data-kid=\"173\">\n                <div class=\"relative\" data-kid=\"174\">\n                    <div class=\"inline-block px-4 py-1.5 bg-[#E53935]/10 rounded-full mb-6\" data-kid=\"175\">\n                        <span class=\"text-[10px] font-black uppercase text-[#E53935] tracking-widest\" data-kid=\"176\">Neighborhood Conquest</span>\n                    </div>\n                    <h2 class=\"text-6xl font-extrabold mb-8 leading-[0.95]\" data-kid=\"177\">Own your <br data-kid=\"178\"><span class=\"text-[#1E88E5]\" data-kid=\"179\">neighborhood.</span></h2>\n                    <p class=\"text-xl text-slate-500 mb-10 leading-relaxed\" data-kid=\"180\">\n                        We push your Google Business Profile to the top 3 pack, guaranteed. Stop letting competitors steal the high-intent traffic in your zip code.\n                    </p>\n                    <ul class=\"space-y-6 mb-12\" data-kid=\"181\">\n                        <li class=\"flex items-center gap-4\" data-kid=\"182\">\n                            <div class=\"w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600\" data-kid=\"183\">\n                                <i class=\"ti ti-check text-lg\" data-kid=\"184\"></i>\n                            </div>\n                            <span class=\"text-lg font-bold text-slate-700\" data-kid=\"185\">Hyper-local Heatmap Analysis</span>\n                        </li>\n                        <li class=\"flex items-center gap-4\" data-kid=\"186\">\n                            <div class=\"w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600\" data-kid=\"187\">\n                                <i class=\"ti ti-check text-lg\" data-kid=\"188\"></i>\n                            </div>\n                            <span class=\"text-lg font-bold text-slate-700\" data-kid=\"189\">Competitor Keyword Displacement</span>\n                        </li>\n                        <li class=\"flex items-center gap-4\" data-kid=\"190\">\n                            <div class=\"w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600\" data-kid=\"191\">\n                                <i class=\"ti ti-check text-lg\" data-kid=\"192\"></i>\n                            </div>\n                            <span class=\"text-lg font-bold text-slate-700\" data-kid=\"193\">Top 3-Pack Authority Scaling</span>\n                        </li>\n                    </ul>\n                    <button class=\"bg-[#111111] text-white px-10 py-5 rounded-2xl font-bold shadow-xl hover:scale-105 transition-transform\" data-kid=\"194\">Audit Your Local Rank</button>\n                </div>\n\n                <div class=\"relative group\" data-kid=\"195\">\n                    <div class=\"flex flex-col gap-8 relative z-10\" data-kid=\"196\">\n                        <div class=\"glass p-8 rounded-[2.5rem] shadow-soft border-slate-200/40 opacity-70 scale-95 transition-all group-hover:opacity-60 grayscale\" data-kid=\"197\">\n                            <div class=\"flex justify-between items-center mb-6\" data-kid=\"198\">\n                                <span class=\"text-xs font-black uppercase tracking-widest text-slate-400\" data-kid=\"199\">Competitors (Before)</span>\n                                <i class=\"ti ti-trending-down text-slate-400\" data-kid=\"200\"></i>\n                            </div>\n                            <div class=\"h-56 bg-white/50 rounded-3xl relative overflow-hidden flex items-center justify-center\" data-kid=\"201\">\n                                <i class=\"ti ti-map-2 text-slate-200 text-[100px] opacity-20\" data-kid=\"202\"></i>\n                                <div class=\"absolute top-8 left-12 w-3 h-3 bg-slate-400 rounded-full blur-xs opacity-40\" data-kid=\"203\"></div>\n                                <div class=\"absolute top-20 right-16 w-3 h-3 bg-slate-400 rounded-full blur-xs opacity-40\" data-kid=\"204\"></div>\n                                <div class=\"absolute top-40 left-24 w-3 h-3 bg-slate-400 rounded-full blur-xs opacity-40\" data-kid=\"205\"></div>\n                                <div class=\"absolute bottom-12 left-10 w-3 h-3 bg-slate-400 rounded-full blur-xs opacity-40\" data-kid=\"206\"></div>\n                                <div class=\"absolute bottom-24 right-32 w-3 h-3 bg-slate-400 rounded-full blur-xs opacity-40\" data-kid=\"207\"></div>\n                                <div class=\"absolute top-32 left-1/2 w-3 h-3 bg-slate-400 rounded-full blur-xs opacity-40\" data-kid=\"208\"></div>\n                            </div>\n                        </div>\n\n                        <div class=\"glass p-8 rounded-[3rem] shadow-2xl border-white scale-105 relative z-20\" data-kid=\"209\">\n                            <div class=\"flex justify-between items-center mb-6\" data-kid=\"210\">\n                                <span class=\"text-xs font-black uppercase tracking-widest text-blue-600\" data-kid=\"211\">Ads Growly (After)</span>\n                                <div class=\"px-3 py-1 bg-green-500 text-white text-[10px] rounded-full font-black uppercase tracking-tighter\" data-kid=\"212\">Live dominance</div>\n                            </div>\n                            <div class=\"h-64 bg-blue-50/50 rounded-[2rem] relative overflow-hidden flex items-center justify-center border border-blue-100\" data-kid=\"213\">\n                                <i class=\"ti ti-map-2 text-blue-500 text-[120px] opacity-5\" data-kid=\"214\"></i>\n                                <div class=\"absolute top-12 left-16 group/pin\" data-kid=\"215\">\n                                    <i class=\"ti ti-map-pin-filled text-blue-600 text-4xl drop-shadow-[0_0_15px_rgba(30,136,229,0.9)] animate-bounce\" data-kid=\"216\"></i>\n                                </div>\n                                <div class=\"absolute top-32 right-24\" data-kid=\"217\">\n                                    <i class=\"ti ti-map-pin-filled text-blue-600 text-4xl drop-shadow-[0_0_15px_rgba(30,136,229,0.9)] animate-pulse\" data-kid=\"218\"></i>\n                                </div>\n                                <div class=\"absolute bottom-16 left-32\" data-kid=\"219\">\n                                    <i class=\"ti ti-map-pin-filled text-blue-600 text-4xl drop-shadow-[0_0_15px_rgba(30,136,229,0.9)] animate-bounce delay-150\" data-kid=\"220\"></i>\n                                </div>\n                            </div>\n                            <div class=\"absolute -bottom-6 left-1/2 -translate-x-1/2 glass-dark px-6 py-3 rounded-full text-white text-xs font-bold shadow-xl flex items-center gap-3\" data-kid=\"221\">\n                                <i class=\"ti ti-navigation-filled text-[#E53935]\" data-kid=\"222\"></i>\n                                <span data-kid=\"223\">Toronto Core Area Heatmap: 98% Optimized</span>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-blue-400/10 blur-[120px] -z-10\" data-kid=\"224\"></div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-32 px-6 bg-[#F4F7F6] relative overflow-hidden\" data-kid=\"225\">\n        <div class=\"max-w-7xl mx-auto relative z-10\" data-kid=\"226\">\n            <div class=\"grid lg:grid-cols-[1fr_380px] gap-16 items-start\" data-kid=\"227\">\n                <div data-kid=\"228\">\n                    <div class=\"mb-16\" data-kid=\"229\">\n                        <span class=\"text-[#E53935] font-black uppercase text-xs tracking-widest mb-4 block\" data-kid=\"230\">Verticals</span>\n                        <h2 class=\"text-6xl font-black tracking-tighter mb-6\" data-kid=\"231\">Built for Canadian <br data-kid=\"232\"><span class=\"text-[#1E88E5]\" data-kid=\"233\">service pros.</span></h2>\n                        <p class=\"text-xl text-slate-500 max-w-xl font-medium\" data-kid=\"234\">Each vertical gets its own playbook — offers, ad angles, and booking flows tuned to how your customers actually buy.</p>\n                    </div>\n\n                    <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\" data-kid=\"235\">\n                        <div class=\"bento-card rounded-[2.5rem] bg-gradient-to-br from-orange-50 to-amber-50 border border-orange-100 p-8\" data-kid=\"236\">\n                            <div class=\"w-14 h-14 rounded-2xl bg-white shadow-soft flex items-center justify-center mb-6\" data-kid=\"237\"><i class=\"ti ti-temperature-sun text-3xl text-orange-500\" data-kid=\"238\"></i></div>\n                            <h3 class=\"text-xl font-bold mb-2\" data-kid=\"239\">HVAC & Cooling</h3>\n                            <p class=\"text-sm text-slate-500 leading-relaxed\" data-kid=\"240\">Emergency call campaigns + seasonal demand surfing for furnace and AC pros.</p>\n                        </div>\n                        <div class=\"bento-card rounded-[2.5rem] bg-gradient-to-br from-blue-50 to-sky-50 border border-blue-100 p-8\" data-kid=\"241\">\n                            <div class=\"w-14 h-14 rounded-2xl bg-white shadow-soft flex items-center justify-center mb-6\" data-kid=\"242\"><i class=\"ti ti-home-shield text-3xl text-[#1E88E5]\" data-kid=\"243\"></i></div>\n                            <h3 class=\"text-xl font-bold mb-2\" data-kid=\"244\">Roofing</h3>\n                            <p class=\"text-sm text-slate-500 leading-relaxed\" data-kid=\"245\">Storm-response funnels and financing-led offers for high-ticket replacements.</p>\n                        </div>\n                        <div class=\"bento-card rounded-[2.5rem] bg-gradient-to-br from-teal-50 to-emerald-50 border border-teal-100 p-8\" data-kid=\"246\">\n                            <div class=\"w-14 h-14 rounded-2xl bg-white shadow-soft flex items-center justify-center mb-6\" data-kid=\"247\"><i class=\"ti ti-dental text-3xl text-teal-500\" data-kid=\"248\"></i></div>\n                            <h3 class=\"text-xl font-bold mb-2\" data-kid=\"249\">Dental Clinics</h3>\n                            <p class=\"text-sm text-slate-500 leading-relaxed\" data-kid=\"250\">Implant & invisalign patient pipelines with review-velocity systems.</p>\n                        </div>\n                        <div class=\"bento-card rounded-[2.5rem] bg-gradient-to-br from-slate-50 to-gray-100 border border-slate-200 p-8\" data-kid=\"251\">\n                            <div class=\"w-14 h-14 rounded-2xl bg-white shadow-soft flex items-center justify-center mb-6\" data-kid=\"252\"><i class=\"ti ti-scale text-3xl text-slate-700\" data-kid=\"253\"></i></div>\n                            <h3 class=\"text-xl font-bold mb-2\" data-kid=\"254\">Legal</h3>\n                            <p class=\"text-sm text-slate-500 leading-relaxed\" data-kid=\"255\">High-intent case capture for personal injury, family, and immigration law.</p>\n                        </div>\n                        <div class=\"bento-card rounded-[2.5rem] bg-gradient-to-br from-red-50 to-rose-50 border border-red-100 p-8\" data-kid=\"256\">\n                            <div class=\"w-14 h-14 rounded-2xl bg-white shadow-soft flex items-center justify-center mb-6\" data-kid=\"257\"><i class=\"ti ti-building-community text-3xl text-[#E53935]\" data-kid=\"258\"></i></div>\n                            <h3 class=\"text-xl font-bold mb-2\" data-kid=\"259\">Real Estate</h3>\n                            <p class=\"text-sm text-slate-500 leading-relaxed\" data-kid=\"260\">Listing-launch ads, brochure funnels, and agent-routing automation.</p>\n                        </div>\n                        <div class=\"bento-card rounded-[2.5rem] bg-gradient-to-br from-indigo-50 to-violet-50 border border-indigo-100 p-8\" data-kid=\"261\">\n                            <div class=\"w-14 h-14 rounded-2xl bg-white shadow-soft flex items-center justify-center mb-6\" data-kid=\"262\"><i class=\"ti ti-car text-3xl text-indigo-500\" data-kid=\"263\"></i></div>\n                            <h3 class=\"text-xl font-bold mb-2\" data-kid=\"264\">Auto Services</h3>\n                            <p class=\"text-sm text-slate-500 leading-relaxed\" data-kid=\"265\">Bay-filling booking flows for detailing, repair, and tire-season spikes.</p>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"hidden lg:flex flex-col items-center gap-8 pt-24\" data-kid=\"266\">\n                    <div class=\"animate-floaty relative\" data-kid=\"267\">\n                        <div class=\"glass p-3 rounded-[2.5rem] shadow-glass border-white/70\" data-kid=\"268\">\n                            <img src=\"https://images.pexels.com/photos/9436715/pexels-photo-9436715.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"3D render of glossy cubes — Pexels\" class=\"w-[320px] h-[420px] object-cover rounded-[2rem]\" decoding=\"async\" loading=\"lazy\" data-kid=\"269\">\n                        </div>\n                        <div class=\"absolute -bottom-6 -left-8 glass px-6 py-4 rounded-2xl shadow-2xl border-white/70 animate-floaty2\" data-kid=\"270\">\n                            <div class=\"text-[9px] font-black uppercase tracking-widest text-slate-400 mb-1\" data-kid=\"271\">Avg. across verticals</div>\n                            <div class=\"text-2xl font-black text-[#E53935]\" data-kid=\"272\">-38% CPL</div>\n                        </div>\n                        <div class=\"absolute -top-6 -right-6 w-16 h-16 bg-[#1E88E5] rounded-2xl shadow-xl shadow-blue-200 flex items-center justify-center rotate-12\" data-kid=\"273\">\n                            <i class=\"ti ti-sparkles text-white text-3xl\" data-kid=\"274\"></i>\n                        </div>\n                    </div>\n                    <p class=\"text-xs font-bold text-slate-400 text-center max-w-[260px]\" data-kid=\"275\">One operating system, six industry playbooks. No generic agency guessing.</p>\n                </div>\n            </div>\n        </div>\n        <div class=\"absolute -bottom-32 -left-32 w-96 h-96 bg-red-100/60 rounded-full blur-[120px]\" data-kid=\"276\"></div>\n    </section>\n\n    \n    \n        <div class=\"max-w-5xl mx-auto font-inter text-center relative z-10\" data-kid=\"277\">\n            <h2 class=\"text-5xl font-black mb-6 leading-tight\" data-kid=\"278\">Stress-test the funnel <br data-kid=\"279\"><span class=\"text-[#E53935]\" data-kid=\"280\">before you spend.</span></h2>\n            <p class=\"text-xl text-slate-500 mb-16 max-w-2xl mx-auto font-medium\" data-kid=\"281\">Stop guessing. We use 5 years of Canadian service sector data to project your ROI before we launch a single ad.</p>\n\n            </div>\n                <div class=\"grid md:grid-cols-2 gap-16 items-center\" data-kid=\"282\">\n                    <div class=\"space-y-12\" data-kid=\"283\">\n                        <div data-kid=\"284\">\n                            <label class=\"block text-xs font-black text-slate-400 uppercase tracking-widest mb-6\" data-kid=\"285\">Your Industry Vertical</label>\n                            <div class=\"relative\" data-kid=\"286\">\n                                <select class=\"w-full appearance-none bg-[#F4F7F6] border border-slate-100 rounded-3xl px-8 py-5 text-xl font-bold focus:outline-none focus:ring-4 focus:ring-blue-100 transition-all cursor-pointer\" data-kid=\"287\">\n                                    <option data-kid=\"288\">Residential Roofing</option>\n                                    <option data-kid=\"289\">HVAC & Cooling</option>\n                                    <option data-kid=\"290\">Emergency Plumbing</option>\n                                    <option data-kid=\"291\">Dental Implants</option>\n                                    <option data-kid=\"292\">Personal Injury Law</option>\n                                </select>\n                                <div class=\"absolute right-8 top-1/2 -translate-y-1/2 pointer-events-none\" data-kid=\"293\">\n                                    <i class=\"ti ti-chevron-down text-slate-400 text-2xl\" data-kid=\"294\"></i>\n                                </div>\n                            </div>\n                        </div>\n                        <div data-kid=\"295\">\n                            <div class=\"flex justify-between items-center mb-6\" data-kid=\"296\">\n                                <label class=\"block text-xs font-black text-slate-400 uppercase tracking-widest\" data-kid=\"297\">Monthly Media Budget</label>\n                                <span class=\"text-2xl font-black text-[#E53935]\" data-kid=\"298\">$7,500</span>\n                            </div>\n                            <input type=\"range\" min=\"1000\" max=\"50000\" step=\"500\" value=\"7500\" class=\"mb-4\" data-kid=\"299\">\n                            <div class=\"flex justify-between text-[10px] font-bold text-slate-400 uppercase\" data-kid=\"300\">\n                                <span data-kid=\"301\">$1k/mo</span>\n                                <span data-kid=\"302\">Scale-up</span>\n                                <span data-kid=\"303\">$50k/mo</span>\n                            </div>\n                        </div>\n                    </div>\n\n                    </div></div>",
